{
	"name": "pdf",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/u29dc/pdf"
	},
	"scripts": {
		"init---------------------------------": "",
		"prepare": "husky",
		"build--------------------------------": "",
		"build": "cargo build --release && mkdir -p \"${PDF_HOME:-${TOOLS_HOME:-$HOME/.tools}/pdf}\" && cp target/release/pdf \"${PDF_HOME:-${TOOLS_HOME:-$HOME/.tools}/pdf}/pdf\"",
		"pdf": "./target/release/pdf",
		"check--------------------------------": "",
		"util:format": "cargo fmt --all",
		"util:format:check": "cargo fmt --all -- --check",
		"util:lint": "cargo clippy --all-targets --all-features -- -D warnings",
		"util:types": "cargo check --all-targets --all-features",
		"util:test": "cargo test --all",
		"util:audit": "cargo audit",
		"util:build": "cargo build --release",
		"util:check": "STATUS=0; bun run util:format:check || STATUS=1; bun run util:lint || STATUS=1; bun run util:types || STATUS=1; bun run util:test || STATUS=1; bun run util:audit || STATUS=1; bun run util:build || STATUS=1; exit $STATUS",
		"util:clean": "cargo clean"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.2",
		"@commitlint/config-conventional": "^20.4.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.1"
	}
}
